ENV=dev
SECRET_KEY=dev-secret-change-me-PLEASE-do-not-use-in-prod-XXXXXXXX
DATABASE_URL=postgresql+asyncpg://myetal:myetal@localhost:5432/myetal

# Where the API is reachable from the OAuth provider's redirect (callback URL base)
PUBLIC_API_URL=http://localhost:8000
# Where the WEB app lives (used in QR codes and the OAuth post-flow bounce)
PUBLIC_BASE_URL=http://localhost:3000

# ORCID OAuth (sandbox by default — flip ORCID_USE_SANDBOX=false for production)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_USE_SANDBOX=true

# ---- Better Auth ----
# Minted on the Next.js side, verified by FastAPI via JWKS. The same
# BETTER_AUTH_SECRET must be present on both sides so JWTs sign &
# verify symmetrically. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the web app. http://localhost:3000 in dev,
# https://myetal.app in prod. Used as the JWT `iss` claim and as the
# base for the JWKS URL.
BETTER_AUTH_URL=http://localhost:3000
# Optional explicit overrides — leave blank to compute from BETTER_AUTH_URL.
# BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
# BETTER_AUTH_ISSUER=http://localhost:3000

# ---- Email (Resend) ----
# Transactional email (password reset, email verification).
# Get a key at https://resend.com → API Keys.
RESEND_API_KEY=
EMAIL_FROM="MyEtAl <noreply@myetal.app>"

# Google OAuth (https://console.cloud.google.com/ → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare R2 — S3-compatible object storage for PDF uploads
# Get values from CF dashboard → R2 → Manage R2 API Tokens → Create
# (token must be "Object Read & Write" scoped to the bucket).
# Bucket must have "Public Development URL" enabled for share viewers.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=myetal-uploads
R2_ENDPOINT=
R2_PUBLIC_URL=
