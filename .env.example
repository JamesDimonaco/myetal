# ============================================================
# .env.example — single template for dev / staging / production
# ============================================================
# Copy to `.env` (dev), `.env.staging` (Pi), or `.env.production` (Railway).
# All three are gitignored (only this file is committed).
#
# Inline tags:
#   [WEB]     — also needs to be set in Vercel's project env (per-environment).
#   [API]     — only the FastAPI side reads this.
#   [DEV]     — dev-only fallback; staging/prod must override.

# ---- App identity ----
ENV=dev   # dev | staging | production

# ---- Database ----
# Dev:        postgres://myetal:myetal@localhost:5432/myetal (docker-compose default)
# Staging:    postgres://myetal_staging:<strong>@db:5432/myetal_staging  (Pi)
# Production: Railway sets this automatically when Postgres plugin is attached.
DATABASE_URL=postgresql+asyncpg://myetal:myetal@localhost:5432/myetal
DATABASE_URL_SYNC=postgresql://myetal:myetal@localhost:5432/myetal

# Postgres credentials (consumed by docker-compose's `db` service).
# Only relevant for compose-managed Postgres (dev + staging on Pi).
POSTGRES_USER=myetal
POSTGRES_PASSWORD=myetal
POSTGRES_DB=myetal

# ---- Better Auth (cross-stack identity) ----
# [WEB][API] Generate with: openssl rand -base64 32
# DIFFERENT secret per environment. The web side (Vercel) and the API
# (Pi/Railway) MUST share the same value within an environment.
BETTER_AUTH_SECRET=
# [WEB][API] Where the BA Next.js handler lives. JWKS + issuer derive from this.
# Dev:        http://localhost:3000
# Staging:    https://staging.myetal.app
# Production: https://myetal.app
BETTER_AUTH_URL=http://localhost:3000
# Optional explicit overrides — leave blank to compute from BETTER_AUTH_URL.
# BETTER_AUTH_JWKS_URL=
# BETTER_AUTH_ISSUER=

# ---- Email (Resend) ----
# [WEB] Better Auth sends transactional email (verify, password reset).
# Until myetal.app is verified in Resend, EMAIL_FROM MUST be
# `onboarding@resend.dev` and `to:` is restricted to the account-owner email.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev   # post-verify: MyEtAl <noreply@myetal.app>

# ---- ORCID OAuth ----
# [WEB][API] Sandbox URLs for dev/staging (use `false` only in production).
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_USE_SANDBOX=true

# ---- Google OAuth ----
# [WEB] Authorized redirect URIs (Google Cloud Console):
#   <BETTER_AUTH_URL>/api/auth/callback/google
#   <BETTER_AUTH_URL>/auth/mobile-bounce
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- GitHub OAuth ----
# [WEB] Authorization callback URL:
#   <BETTER_AUTH_URL>/api/auth/callback/github
#   <BETTER_AUTH_URL>/auth/mobile-bounce
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Cloudflare R2 (PDF storage) ----
# [API] Recommend a SEPARATE bucket per environment so test PDFs don't
# pollute prod storage (e.g. myetal-uploads / myetal-uploads-staging).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=myetal-uploads
R2_ENDPOINT=
R2_PUBLIC_URL=

# ---- Public URLs (used in QR codes, email links, OAuth callbacks) ----
# Dev:        http://localhost:8000 / http://localhost:3000
# Staging:    https://staging-api.myetal.app / https://staging.myetal.app
# Production: https://api.myetal.app / https://myetal.app
PUBLIC_API_URL=http://localhost:8000
PUBLIC_BASE_URL=http://localhost:3000

# ---- CORS (only set if hitting API directly from a browser on a different origin) ----
# Empty string fails pydantic parsing — leave commented OR set a real value.
# CORS_ORIGINS=https://myetal.app,https://www.myetal.app

# ---- Admin allowlist (no JWT trust; re-checked in DB-bound dep) ----
# When read from a `.env` file by pydantic-settings: comma-separated works
# (e.g. ADMIN_EMAILS=foo@x.com,bar@y.com).
# When read from container env vars (docker compose env_file:): you MUST
# use JSON format (e.g. ADMIN_EMAILS=["foo@x.com","bar@y.com"]).
# Same rule applies to CORS_ORIGINS.
# ADMIN_EMAILS=["james@example.com"]

# ---- Observability ----
# [WEB][API] PostHog for product analytics + error tracking.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Telegram bot (admin feedback notifications) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
