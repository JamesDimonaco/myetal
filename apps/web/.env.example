# MyEtAl web app env vars.
#
# All values here are non-secret defaults / placeholders. Real secrets live
# in `.env.local` (gitignored) for local dev and in Vercel project env vars
# for production.

# ---- API connection ----
# Where the FastAPI backend is reachable from the Next.js server runtime.
# In Docker compose this is http://api:8000; on bare metal usually
# http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Better Auth ----
# Mounted at /api/auth/[...all] (Phase 3 collapsed the Phase 0
# /api/ba-auth safety mount).

# Cryptographic secret used by Better Auth for signing & encryption.
# Must be at least 32 characters. MUST match BETTER_AUTH_SECRET on the
# API side so JWTs verify across the boundary. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL of the Next.js app. Better Auth uses this to compose
# absolute URLs for OAuth callbacks and to populate the JWT `iss` claim.
BETTER_AUTH_URL=http://localhost:3000

# Postgres connection string. Reuses the same DB the FastAPI side uses.
# After the Phase 1 cutover Better Auth shares the `users` table with
# the API; the `session`, `account`, `verification`, and `jwks` tables
# are managed by Alembic (see apps/api/alembic/versions/0016_*.py).
# Accept either the SQLAlchemy-flavoured `postgresql+asyncpg://` URL or
# a plain `postgresql://` — `src/lib/db.ts` strips the `+asyncpg` suffix.
DATABASE_URL=postgresql://myetal:myetal@localhost:5432/myetal

# ---- OAuth providers ----
# Google: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# ORCID: https://orcid.org/developer-tools
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_USE_SANDBOX=true     # use sandbox.orcid.org in dev

# ---- Email (Resend) ----
# Required for password reset + email verification. Empty in dev =
# auth flows still succeed; mail is logged-and-skipped with a warning.
# Get a key at https://resend.com → API Keys.
RESEND_API_KEY=
EMAIL_FROM="MyEtAl <noreply@myetal.app>"
