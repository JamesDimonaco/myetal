ENV=dev
SECRET_KEY=dev-secret-change-me-PLEASE-do-not-use-in-prod-XXXXXXXX
DATABASE_URL=postgresql+asyncpg://myetal:myetal@localhost:5432/myetal

# Where the API is reachable from the OAuth provider's redirect (callback URL base)
PUBLIC_API_URL=http://localhost:8000
# Where the WEB app lives (used in QR codes and the OAuth post-flow bounce)
PUBLIC_BASE_URL=http://localhost:3000

# ORCID OAuth (sandbox by default — flip ORCID_USE_SANDBOX=false for production)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_USE_SANDBOX=true

# Google OAuth (https://console.cloud.google.com/ → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Production hardening ----
# Sentry DSN (errors + traces). Empty = disabled, which is the dev default.
SENTRY_DSN=
# Fraction of requests to trace (0.0–1.0). 0.1 = 10% sampling.
SENTRY_TRACES_SAMPLE_RATE=0.1

# CORS origins — comma-separated, exact match. Empty (default) = no CORS
# headers emitted, suitable for the prod setup where mobile is native and the
# web app proxies through Next.js. Set this only if you start hitting the API
# directly from a browser on a different origin.
# CORS_ORIGINS=https://myetal.app,https://www.myetal.app
CORS_ORIGINS=
